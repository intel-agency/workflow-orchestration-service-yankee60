{
  "name": "ai-new-workflow-app-template",
  "image": "ghcr.io/intel-agency/workflow-orchestration-prebuild/devcontainer:main-latest",
  "containerEnv": {
    "DOTNET_ROOT": "/usr/share/dotnet"
  },
  "remoteEnv": {
    "GITHUB_TOKEN": "${localEnv:GH_ORCHESTRATION_AGENT_TOKEN}",
    "GITHUB_PERSONAL_ACCESS_TOKEN": "${localEnv:GH_ORCHESTRATION_AGENT_TOKEN}",
    "GH_ORCHESTRATION_AGENT_TOKEN": "${localEnv:GH_ORCHESTRATION_AGENT_TOKEN}",
    "ZHIPU_API_KEY": "${localEnv:ZHIPU_API_KEY}",
    "KIMI_CODE_ORCHESTRATOR_AGENT_API_KEY": "${localEnv:KIMI_CODE_ORCHESTRATOR_AGENT_API_KEY}",
    "KIMI_API_KEY": "${localEnv:KIMI_CODE_ORCHESTRATOR_AGENT_API_KEY}",
    "OPENAI_API_KEY": "${localEnv:OPENAI_API_KEY}",
    "GOOGLE_GENERATIVE_AI_API_KEY": "${localEnv:GEMINI_API_KEY}",
    "OPENCODE_SERVER_HOSTNAME": "${localEnv:OPENCODE_SERVER_HOSTNAME}",
    "OPENCODE_SERVER_PORT": "${localEnv:OPENCODE_SERVER_PORT}",
    "OPENCODE_SERVER_USERNAME": "${localEnv:OPENCODE_SERVER_USERNAME}",
    "OPENCODE_SERVER_PASSWORD": "${localEnv:OPENCODE_SERVER_PASSWORD}",
    "MCP_MEMORY_STORAGE_BACKEND": "sqlite_vec",
    "MCP_MEMORY_SQLITE_PATH": "${containerWorkspaceFolder}/.memory/memory.db",
    "MCP_MEMORY_SQLITE_PRAGMAS": "busy_timeout=15000,journal_mode=WAL,synchronous=NORMAL"
  },
  "forwardPorts": [
    4096
  ],
  "postStartCommand": "bash ./scripts/start-opencode-server.sh",
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-dotnettools.csdevkit",
        "oven.bun-vscode",
        "avaloniateam.vscode-avalonia"
      ]
    }
  },
  "remoteUser": "vscode"
}