# ============================================================================
# Local Orchestration Environment Variables
# ============================================================================
# Copy this file to .env and fill in the values.
#   cp .env.example .env
#
# Then source it before running scripts:
#   set -a; source .env; set +a
#
# Or use the setup helper:
#   bash scripts/setup-local-env.sh
# ============================================================================

# ---------------------------------------------------------------------------
# REQUIRED — Orchestration will not start without these
# ---------------------------------------------------------------------------

# GitHub Personal Access Token (org-level PAT)
# Required scopes: repo, workflow, project, read:org
# Used by: gh CLI, opencode MCP GitHub server, orchestrator agent
GH_ORCHESTRATION_AGENT_TOKEN=

# ZhipuAI API key — access to GLM models (primary model provider)
ZHIPU_API_KEY=

# Kimi / Moonshot API key — backup model provider
KIMI_CODE_ORCHESTRATOR_AGENT_API_KEY=

# ---------------------------------------------------------------------------
# OPTIONAL — Additional model providers
# ---------------------------------------------------------------------------

# OpenAI API key (GPT models)
# OPENAI_API_KEY=

# Google Gemini API key (mapped to GOOGLE_GENERATIVE_AI_API_KEY in container)
# GEMINI_API_KEY=

# ---------------------------------------------------------------------------
# OPTIONAL — Server configuration (defaults shown)
# ---------------------------------------------------------------------------

# Bind address for opencode serve (0.0.0.0 = all interfaces)
# OPENCODE_SERVER_HOSTNAME=0.0.0.0

# Listen port for opencode serve
# OPENCODE_SERVER_PORT=4096

# ---------------------------------------------------------------------------
# OPTIONAL — Server authentication (for LAN access)
# ---------------------------------------------------------------------------

# Basic auth credentials — when set, clients must include these in attach URLs
# OPENCODE_SERVER_USERNAME=
# OPENCODE_SERVER_PASSWORD=
